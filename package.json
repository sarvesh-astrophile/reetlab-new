{
  "name": "reetlab-new",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "next-themes": "^0.4.6",
      "@types/react-dom": "^19.2.3",
      "alchemy": "^0.91.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "deploy": "turbo -F @reetlab-new/infra deploy",
    "destroy": "turbo -F @reetlab-new/infra destroy",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@reetlab-new/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@reetlab-new/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.3"
}
